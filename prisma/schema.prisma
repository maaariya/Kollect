generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  PENDING
  ACCEPTED
  DEPOSIT_PAID
  CARDS_SENT
  COMPLETED
  DECLINED
  DISPUTED
}

model User {
  id                     Int              @id @default(autoincrement())
  name                   String
  email                  String           @unique
  password               String
  bio                    String?
  phone                  String?
  avatarUrl              String?
  receivedFriendRequests Friendship[]     @relation("ReceivedRequests")
  sentFriendRequests     Friendship[]     @relation("SentRequests")
  receivedMessages       Message[]        @relation("receivedMessages")
  sentMessages           Message[]        @relation("sentMessages")
  cards                  UserCard[]
  wishlist               WishlistCard[]
  tradingListings        TradingListing[]
  tradesSent             Trade[]          @relation("tradeSender")
  tradesReceived         Trade[]          @relation("tradeReceiver")
  notifications          Notification[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Card {
  id          Int              @id @default(autoincrement())
  name        String
  member      String
  group       String
  album       String
  image       String?
  createdAt   DateTime         @default(now())
  users       UserCard[]
  wishlistedBy WishlistCard[]
  tradingListings TradingListing[]

  offeredInTrades   Trade[] @relation("offeredCard")
  requestedInTrades Trade[] @relation("requestedCard")
}

model UserCard {
  id     Int  @id @default(autoincrement())
  userId Int
  cardId Int
  card   Card @relation(fields: [cardId], references: [id])
  user   User @relation(fields: [userId], references: [id])

  @@unique([userId, cardId])
}

model WishlistCard {
  id     Int  @id @default(autoincrement())
  userId Int
  cardId Int
  card   Card @relation(fields: [cardId], references: [id])
  user   User @relation(fields: [userId], references: [id])

  @@unique([userId, cardId])
}

model Friendship {
  id          Int       @id @default(autoincrement())
  requesterId Int?
  recipientId Int?
  createdAt   DateTime? @db.Date
  status      String?   @default("pending")
  recipient   User?     @relation("ReceivedRequests", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_friendship_recipient")
  requester   User?     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_friendship_requester")

  @@unique([requesterId, recipientId], map: "uq_friendship_requester_recipient")
}

model Message {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  tradeId    Int?
  trade      Trade?    @relation(fields: [tradeId], references: [id])
  receiver   User      @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_receiver")
  sender     User      @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sender")
}

model TradingListing {
  id        Int      @id @default(autoincrement())
  userId    Int
  cardId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
}

model Trade {
  id              Int      @id @default(autoincrement())
  senderId        Int
  receiverId      Int
  offeredCardId   Int
  requestedCardId Int
  createdAt       DateTime @default(now())
  status TradeStatus @default(PENDING)

  senderDepositPaid   Boolean @default(false)
  receiverDepositPaid Boolean @default(false)
  senderCardSent      Boolean @default(false)
  receiverCardSent    Boolean @default(false)
  senderConfirmed     Boolean @default(false)
  receiverConfirmed   Boolean @default(false)

  sender        User      @relation("tradeSender",   fields: [senderId],        references: [id])
  receiver      User      @relation("tradeReceiver", fields: [receiverId],       references: [id])
  offeredCard   Card      @relation("offeredCard",   fields: [offeredCardId],   references: [id])
  requestedCard Card      @relation("requestedCard", fields: [requestedCardId], references: [id])
  messages      Message[]
}
